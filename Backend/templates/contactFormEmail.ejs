<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact Form Submission - <%= name %></title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
        background-color: #f5f5f5;
        color: #333333;
        line-height: 1.6;
        padding: 40px 20px;
        -webkit-font-smoothing: antialiased;
      }

      .email-wrapper {
        max-width: 680px;
        margin: 0 auto;
        background-color: #ffffff;
        border: 1px solid #dddddd;
      }

      /* Header */
      .header {
        background-color: #1a1a1a;
        padding: 32px 40px;
        border-bottom: 3px solid #0066cc;
      }

      .header-title {
        font-size: 18px;
        font-weight: 600;
        color: #ffffff;
        margin-bottom: 4px;
        letter-spacing: -0.3px;
      }

      .header-subtitle {
        font-size: 13px;
        color: #aaaaaa;
        font-weight: 400;
      }

      /* Metadata Bar */
      .metadata {
        background-color: #fafafa;
        padding: 16px 40px;
        border-bottom: 1px solid #e5e5e5;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
      }

      .metadata-item {
        font-size: 12px;
        color: #666666;
      }

      .metadata-label {
        font-weight: 600;
        color: #333333;
        margin-right: 6px;
      }

      /* Content */
      .content {
        padding: 32px 40px;
      }

      .section {
        margin-bottom: 28px;
      }

      .section:last-child {
        margin-bottom: 0;
      }

      .section-title {
        font-size: 11px;
        font-weight: 700;
        color: #666666;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 2px solid #0066cc;
      }

      /* Info Table */
      .info-table {
        width: 100%;
        border-collapse: collapse;
      }

      .info-table tr {
        border-bottom: 1px solid #e5e5e5;
      }

      .info-table tr:last-child {
        border-bottom: none;
      }

      .info-table td {
        padding: 16px 0;
        vertical-align: top;
      }

      .info-label {
        width: 140px;
        font-size: 13px;
        font-weight: 600;
        color: #666666;
      }

      .info-value {
        font-size: 14px;
        color: #1a1a1a;
        word-break: break-word;
      }

      .info-value.email-address {
        color: #0066cc;
        text-decoration: none;
      }

      .info-value.email-address:hover {
        text-decoration: underline;
      }

      /* Message Content */
      .message-container {
        background-color: #fafafa;
        border: 1px solid #e5e5e5;
        border-left: 4px solid #0066cc;
        padding: 24px;
        border-radius: 2px;
      }

      .message-text {
        font-size: 14px;
        color: #333333;
        line-height: 1.8;
        white-space: pre-wrap;
        word-wrap: break-word;
      }

      /* Action Button */
      .action-section {
        margin-top: 32px;
        padding-top: 28px;
        border-top: 1px solid #e5e5e5;
        text-align: center;
      }

      .action-button {
        display: inline-block;
        background-color: #0066cc;
        color: #ffffff !important;
        padding: 14px 40px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        border-radius: 3px;
        transition: background-color 0.2s ease;
        letter-spacing: 0.3px;
        border: none;
      }

      .action-button:hover {
        background-color: #0052a3;
        color: #ffffff !important;
        text-decoration: none;
      }

      .action-note {
        margin-top: 16px;
        font-size: 12px;
        color: #666666;
      }

      /* Footer */
      .footer {
        background-color: #fafafa;
        padding: 32px 40px;
        border-top: 1px solid #e5e5e5;
        text-align: center;
      }

      .footer-brand {
        font-size: 15px;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 8px;
      }

      .footer-role {
        font-size: 12px;
        color: #666666;
        margin-bottom: 16px;
      }

      .footer-link {
        color: #0066cc;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
      }

      .footer-link:hover {
        text-decoration: underline;
      }

      .footer-divider {
        height: 1px;
        background-color: #e5e5e5;
        margin: 20px 0;
      }

      .footer-legal {
        font-size: 11px;
        color: #999999;
        line-height: 1.6;
      }

      /* Responsive Design */
      @media (max-width: 640px) {
        body {
          padding: 0;
        }

        .header,
        .content {
          padding: 24px 20px;
        }

        .metadata {
          padding: 12px 20px;
          flex-direction: column;
          align-items: flex-start;
        }

        .info-table td {
          display: block;
          width: 100%;
          padding: 8px 0;
        }

        .info-label {
          width: 100%;
          margin-bottom: 4px;
        }

        .info-table tr {
          border-bottom: 1px solid #e5e5e5;
          padding: 12px 0;
          display: block;
        }

        .message-container {
          padding: 16px;
        }

        .action-button {
          display: block;
          width: 100%;
        }

        .footer {
          padding: 24px 20px;
        }
      }

      /* Print Styles */
      @media print {
        body {
          background-color: #ffffff;
          padding: 0;
        }

        .email-wrapper {
          border: none;
        }

        .action-section {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="email-wrapper">
      <!-- Header -->
      <div class="header">
        <div class="header-title">Portfolio Contact Form Submission</div>
        <div class="header-subtitle">New inquiry received via tejanarra.space</div>
      </div>

      <!-- Metadata Bar -->
      <div class="metadata">
        <div class="metadata-item">
          <span class="metadata-label">Date:</span>
          <span><%= new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
        </div>
        <div class="metadata-item">
          <span class="metadata-label">Time:</span>
          <span><%= new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', timeZoneName: 'short' }) %></span>
        </div>
        <div class="metadata-item">
          <span class="metadata-label">Source:</span>
          <span>Contact Form</span>
        </div>
      </div>

      <!-- Main Content -->
      <div class="content">
        <!-- Contact Information -->
        <div class="section">
          <div class="section-title">Contact Information</div>
          <table class="info-table">
            <tr>
              <td class="info-label">Full Name</td>
              <td class="info-value"><%= name %></td>
            </tr>
            <tr>
              <td class="info-label">Email Address</td>
              <td class="info-value">
                <a href="mailto:<%= email %>" class="email-address"><%= email %></a>
              </td>
            </tr>
            <tr>
              <td class="info-label">Subject</td>
              <td class="info-value"><%= subject %></td>
            </tr>
          </table>
        </div>

        <!-- Message Content -->
        <div class="section">
          <div class="section-title">Message</div>
          <div class="message-container">
            <div class="message-text"><%= message %></div>
          </div>
        </div>

        <!-- Action Button -->
        <div class="action-section">
          <a href="mailto:<%= email %>?subject=Re: <%= encodeURIComponent(subject) %>" class="action-button">
            Reply to Inquiry
          </a>
          <div class="action-note">This will open your default email client</div>
        </div>
      </div>

      <!-- Footer -->
      <div class="footer">
        <div class="footer-brand">Sri Sai Teja Narra</div>
        <div class="footer-role">Full Stack Developer</div>
        <a href="https://tejanarra.space" class="footer-link">tejanarra.space</a>
        
        <div class="footer-divider"></div>
        
        <div class="footer-legal">
          This is an automated notification from your portfolio contact form.<br>
          Please do not reply directly to this email.
        </div>
      </div>
    </div>

  </body>
</html>